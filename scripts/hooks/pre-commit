#!/usr/bin/env bash
# Pre-commit hook: TWO checks
#  1. STALENESS: abort if any sport's player-game-logs parquet is older
#     than 7 days while that sport is in season. Catches the bug where
#     the model was used to suggest bets for a game whose data was never
#     in the cache (NBA Finals 2026, discovered June 9).
#  2. CODEGRAPH: verify codegraph sees all key symbols as having callers.
#     Catches dynamic-import-in-try/except regressions (the one fixed in
#     commit 3945c11 where 9 sport scanners were invisible to codegraph).
#
# Skip with: git commit --no-verify
# Re-run manually: ./scripts/hooks/pre-commit
set -e

# === CHECK 1: STALENESS =================================================
# For each sport in season, latest game_date must be within 7 days.
# Hard-fails (cannot be overridden here — only morning_scan honors env).
# Prefer the repo-local venv python (has pandas/numpy); fall back to
# system python3 (will skip if deps missing).
echo
echo "  [1/2] staleness check (sport cache freshness)..."
if [ -x ".venv/bin/python" ]; then
  PY=".venv/bin/python"
elif command -v python3 &> /dev/null; then
  PY="python3"
else
  echo "  [staleness] no python found — skipping (not recommended)"
  PY=""
fi
if [ -n "$PY" ]; then
  if ! "$PY" -m src.utils.staleness; then
    echo
    echo "  STALENESS CHECK FAILED — refusing to commit"
    echo "  Tip: refresh the stale sport's cache, or use --no-verify to skip"
    exit 1
  fi
fi

# === CHECK 2: CODEGRAPH =================================================
# Key symbols whose callers must NOT disappear. Add new ones here.
# Use MODULE PATHS (src.x.y) — codegraph indexes by module, not by
# class name. Class-name lookups (KalshiClient, RiskManager) return
# "no callers" because class methods aren't tracked as callers.
SYMBOLS=(
  "nba_bet"
  "kalshi_mlb_unified"
  "src.execution.risk"
  "src.data.kalshi"
)

echo
echo "  [2/2] codegraph callers check..."
if ! command -v codegraph &> /dev/null; then
  echo "  [codegraph] CLI not installed — skipping pre-commit check"
  echo "  (install with: npm i -g @codegraph/cli)"
  exit 0
fi

# --- Re-index (incremental, fast) --------------------------------------
codegraph sync > /dev/null 2>&1 || true

# --- Check each symbol --------------------------------------------------
failed=0
checked=0
for sym in "${SYMBOLS[@]}"; do
  out=$(codegraph callers "$sym" 2>&1 || true)
  checked=$((checked + 1))
  if echo "$out" | grep -q "No callers"; then
    echo "  [codegraph] FAIL: '$sym' has NO callers (dynamic-import regression?)"
    failed=1
  elif echo "$out" | grep -q "Callers of"; then
    # Extract the count from the header line: Callers of "X" (N):
    count=$(echo "$out" | grep -oE 'Callers of "[^"]*" \([0-9]+\)' | grep -oE '[0-9]+' | head -1)
    count=${count:-0}
    echo "  [codegraph] OK:   '$sym' has $count caller(s)"
  else
    echo "  [codegraph] WARN: '$sym' query returned unexpected output:"
    echo "$out" | sed 's/^/      /'
  fi
done

if [ $failed -eq 1 ]; then
  echo ""
  echo "  Codegraph pre-commit FAILED ($checked symbols checked)"
  echo "  Likely cause: a new dynamic import was added inside try/except"
  echo "  Fix: hoist the import to module top, OR remove it from SYMBOLS"
  echo "  Skip with: git commit --no-verify"
  exit 1
fi

echo "  [codegraph] $checked symbols all have callers ✓"
exit 0
